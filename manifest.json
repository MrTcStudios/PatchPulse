{
  "manifest_version": 3,
  "name": "PatchPulse",
  "version": "1.1.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "patchpulse@patchpulse.app",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["webNavigation", "tabs", "storage"],
  "background": {
    "scripts": ["lib/match.js", "background.js"]
  },
  "action": {
    "default_title": "PatchPulse",
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
